[Unit]
Description=pi-webrtc single-camera agent (libcamera, Zero 2 W)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=/etc/pi-webrtc/device.env
ExecStart=/usr/bin/python3 /usr/local/bin/pi-webrtc-agent-zero.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
